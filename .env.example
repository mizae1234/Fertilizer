# ============================================
# Fertilizer POS — Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ── PostgreSQL Database ──
POSTGRES_USER=fertilizer
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=fertilizer_pos

# DATABASE_URL is auto-constructed in docker-compose.yml
# Only set this if running outside Docker:
# DATABASE_URL="postgresql://fertilizer:password@localhost:5432/fertilizer_pos?schema=public&options=-c%20timezone%3DAsia%2FBangkok"

# ── App Settings ──
TZ=Asia/Bangkok
JWT_SECRET=CHANGE_ME_random_32_char_secret_here

# ── Site Domain (update Caddyfile too) ──
# SITE_DOMAIN=shop1.example.com
