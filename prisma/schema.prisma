generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum TransactionType {
  GOODS_RECEIVE
  SALE
  SALE_CANCEL
  SALE_RETURN
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  FACTORY_RETURN
}

// ============ Users ============
model User {
  id                  String     @id @default(cuid())
  username            String     @unique
  password            String
  name                String
  role                UserRole   @default(STAFF)
  allowedMenus        Json? // string[] of allowed menu hrefs, null = all access
  defaultWarehouseId  String?
  printSetting        String     @default("bill") // "bill" | "invoice" | "none"
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deletedAt           DateTime?

  defaultWarehouse  Warehouse? @relation("UserDefaultWarehouse", fields: [defaultWarehouseId], references: [id])
  goodsReceives     GoodsReceive[]
  sales             Sale[]
  stockTransfers    StockTransfer[]
  expenses          Expense[]
  stockTransactions StockTransaction[]
  productLogs       ProductLog[]
  factoryReturns    FactoryReturn[]
  saleReturns       SaleReturn[]
  saleEditLogs      SaleEditLog[]
  quotations        Quotation[]
}

// ============ Warehouse ============
model Warehouse {
  id        String    @id @default(cuid())
  name      String
  location  String?
  isActive  Boolean   @default(true)
  isMain    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  productStocks         ProductStock[]
  goodsReceiveItems     GoodsReceiveItem[]
  saleItems             SaleItem[]
  stockTransactionsFrom StockTransfer[]     @relation("FromWarehouse")
  stockTransactionsTo   StockTransfer[]     @relation("ToWarehouse")
  stockTransactions     StockTransaction[]
  stockTransferItems    StockTransferItem[]
  receiptTemplates      ReceiptTemplate[]
  factoryReturnItems    FactoryReturnItem[]
  defaultWarehouseUsers User[]              @relation("UserDefaultWarehouse")
  saleReturnItems       SaleReturnItem[]
}

// ============ Receipt Templates ============
model ReceiptTemplate {
  id           String   @id @default(cuid())
  warehouseId  String?
  name         String   @default("Default")
  isDefault    Boolean  @default(false)
  showLogo     Boolean  @default(false)
  logoUrl      String?  @db.Text
  headerText   String   @default("")
  footerText   String   @default("")
  specialNote  String?  @db.Text // โน๊ตพิเศษ แสดงเฉพาะใบ A4
  showBillNo   Boolean  @default(true)
  showVat      Boolean  @default(false)
  showQr       Boolean  @default(false)
  qrCodeUrl    String?  @db.Text
  showStaff    Boolean  @default(true)
  showCustomer Boolean  @default(true)
  paperSize    String   @default("58mm") // 58mm, 80mm, A4
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
}

// ============ Product Groups (Master) ============
model ProductGroup {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

// ============ Products ============
model Product {
  id             String    @id @default(cuid())
  code           String    @unique
  name           String
  description    String?
  unit           String    @default("bag")
  cost           Decimal   @default(0) @db.Decimal(12, 2)
  price          Decimal   @default(0) @db.Decimal(12, 2)
  brand          String?
  packaging      String?
  productGroupId String?
  pointsPerUnit  Int       @default(0)
  minStock       Int       @default(10)
  imageUrl       String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  productGroup       ProductGroup?       @relation(fields: [productGroupId], references: [id])
  productStocks      ProductStock[]
  productPrices      ProductPrice[]
  productUnits       ProductUnit[]
  goodsReceiveItems  GoodsReceiveItem[]
  saleItems          SaleItem[]
  stockTransferItems StockTransferItem[]
  stockTransactions  StockTransaction[]
  bundleItems        ProductBundleItem[]
  productLogs        ProductLog[]
  factoryReturnItems FactoryReturnItem[]
  saleReturnItems    SaleReturnItem[]
  quotationItems     QuotationItem[]
}

// ============ Product Audit Log ============
model ProductLog {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  action    String // CREATE, UPDATE, DELETE, PRICE_CHANGE, UNIT_CHANGE, etc.
  field     String? // which field changed
  oldValue  String? // previous value
  newValue  String? // new value
  details   String?  @db.Text // human-readable summary
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])
}

model ProductStock {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int      @default(0)
  avgCost     Decimal  @default(0) @db.Decimal(12, 2)
  lastCost    Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
}

model ProductPrice {
  id              String   @id @default(cuid())
  productId       String
  customerGroupId String
  productUnitId   String?
  price           Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product       Product       @relation(fields: [productId], references: [id])
  customerGroup CustomerGroup @relation(fields: [customerGroupId], references: [id])
  productUnit   ProductUnit?  @relation(fields: [productUnitId], references: [id])

  @@unique([productId, customerGroupId, productUnitId])
}

// ============ Product Units (Multi Unit Pricing) ============
model ProductUnit {
  id             String   @id @default(cuid())
  productId      String
  unitName       String
  conversionRate Decimal  @db.Decimal(12, 4)
  sellingPrice   Decimal  @db.Decimal(12, 2)
  isBaseUnit     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  productPrices ProductPrice[]

  @@unique([productId, unitName])
}

// ============ Customers ============
model CustomerGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers     Customer[]
  productPrices ProductPrice[]
}

model Customer {
  id              String    @id @default(cuid())
  name            String
  phone           String
  customerGroupId String
  address         String?
  taxId           String?
  totalPoints     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  customerGroup     CustomerGroup      @relation(fields: [customerGroupId], references: [id])
  pointTransactions PointTransaction[]
  sales             Sale[]
  quotations        Quotation[]
}

model PointTransaction {
  id          String   @id @default(cuid())
  customerId  String
  points      Int
  type        String // "EARN" | "REDEEM"
  reference   String? // sale id, etc.
  description String? // redeem note / reward detail
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

// ============ Vendors ============
model Vendor {
  id        String    @id @default(cuid())
  name      String
  phone     String?
  lineId    String?
  address   String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  goodsReceives  GoodsReceive[]
  factoryReturns FactoryReturn[]
}

// ============ Goods Receive ============
model GoodsReceive {
  id           String      @id @default(cuid())
  grNumber     String      @unique
  poNumber     String?
  vendorId     String
  status       OrderStatus @default(PENDING)
  totalAmount  Decimal     @default(0) @db.Decimal(12, 2)
  notes        String?
  receivedDate DateTime    @default(now())
  createdById  String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  vendor    Vendor             @relation(fields: [vendorId], references: [id])
  createdBy User               @relation(fields: [createdById], references: [id])
  items     GoodsReceiveItem[]
}

model GoodsReceiveItem {
  id             String  @id @default(cuid())
  goodsReceiveId String
  productId      String
  warehouseId    String
  quantity       Int
  unitCost       Decimal @db.Decimal(12, 2)
  totalCost      Decimal @db.Decimal(12, 2)
  lotNo          String?

  goodsReceive GoodsReceive @relation(fields: [goodsReceiveId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])
}

// ============ Sales ============
model Sale {
  id            String      @id @default(cuid())
  saleNumber    String      @unique
  customerId    String?
  status        OrderStatus @default(PENDING)
  totalAmount   Decimal     @default(0) @db.Decimal(12, 2)
  totalPoints   Int         @default(0)
  paymentMethod String      @default("CASH") // CASH, CREDIT_CARD, CREDIT
  creditDueDate DateTime?
  payments      Json? // [{ method: "CASH", amount: 200 }, { method: "CREDIT", amount: 800, dueDate: "..." }]
  notes         String?
  discount      Decimal     @default(0) @db.Decimal(12, 2)
  cashReceived  Decimal?    @db.Decimal(12, 2)
  createdById   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  createdBy     User           @relation(fields: [createdById], references: [id])
  customer      Customer?      @relation(fields: [customerId], references: [id])
  items         SaleItem[]
  debtPayments  DebtPayment[]
  debtInterests DebtInterest[]
  saleReturns   SaleReturn[]
  saleEditLogs  SaleEditLog[]
}

// ============ Debt Management ============
model DebtPayment {
  id      String    @id @default(cuid())
  saleId  String
  amount  Decimal   @db.Decimal(12, 2)
  method  String // CASH, TRANSFER, CREDIT
  dueDate DateTime? // new due date if method is CREDIT
  note    String?
  paidAt  DateTime  @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model DebtInterest {
  id         String   @id @default(cuid())
  saleId     String
  percentage Decimal  @db.Decimal(5, 2)
  baseAmount Decimal  @db.Decimal(12, 2) // ยอดค้างที่ใช้คำนวณ
  amount     Decimal  @db.Decimal(12, 2) // จำนวนดอกเบี้ย
  note       String?
  createdAt  DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String
  productId   String
  warehouseId String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  points         Int     @default(0)
  unitName       String?
  conversionRate Decimal @default(1) @db.Decimal(12, 4)

  sale      Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
}

// ============ Stock Transfers ============
model StockTransfer {
  id              String      @id @default(cuid())
  transferNumber  String      @unique
  fromWarehouseId String
  toWarehouseId   String
  status          OrderStatus @default(PENDING)
  notes           String?
  createdById     String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  createdBy     User                @relation(fields: [createdById], references: [id])
  fromWarehouse Warehouse           @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse           @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  items         StockTransferItem[]
}

model StockTransferItem {
  id              String @id @default(cuid())
  stockTransferId String
  productId       String
  warehouseId     String
  quantity        Int

  stockTransfer StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
  warehouse     Warehouse     @relation(fields: [warehouseId], references: [id])
}

// ============ Stock Transactions ============
model StockTransaction {
  id          String          @id @default(cuid())
  productId   String
  warehouseId String
  type        TransactionType
  quantity    Int
  unitCost    Decimal         @default(0) @db.Decimal(12, 2)
  reference   String? // PO id, Sale id, Transfer id
  lotNo       String?
  notes       String?
  userId      String?
  createdAt   DateTime        @default(now())

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  user      User?     @relation(fields: [userId], references: [id])
}

// ============ Expenses ============
model Expense {
  id            String    @id @default(cuid())
  expenseNumber String    @unique
  category      String // ค่าขนส่ง, ค่าน้ำมัน, ค่าเช่า, ค่าแรง, อื่นๆ
  amount        Decimal   @db.Decimal(12, 2)
  description   String?
  reference     String? // เลขที่ใบเสร็จ/อ้างอิง
  expenseDate   DateTime  @default(now())
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  createdBy User @relation(fields: [createdById], references: [id])
}

// ============ Bank Accounts ============
model BankAccount {
  id            String   @id @default(cuid())
  accountName   String
  accountNumber String
  bankName      String
  qrCodeUrl     String?  @db.Text
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============ Product Bundles (ชุดสินค้า) ============
model ProductBundle {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?
  bundlePrice Decimal   @db.Decimal(12, 2)
  bundleCost  Decimal   @default(0) @db.Decimal(12, 2)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  items ProductBundleItem[]
}

model ProductBundleItem {
  id        String @id @default(cuid())
  bundleId  String
  productId String
  quantity  Int

  bundle  ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id])

  @@unique([bundleId, productId])
}

// ============ Factory Returns (เคลมคืนโรงงาน) ============
model FactoryReturn {
  id           String      @id @default(cuid())
  returnNumber String      @unique
  vendorId     String
  status       OrderStatus @default(APPROVED)
  totalAmount  Decimal     @default(0) @db.Decimal(12, 2)
  notes        String?
  returnDate   DateTime    @default(now())
  senderName   String? // ผู้ส่งสินค้าคืน
  receiverName String? // ผู้ตรวจนับและรับสินค้าคืน
  createdById  String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  vendor    Vendor              @relation(fields: [vendorId], references: [id])
  createdBy User                @relation(fields: [createdById], references: [id])
  items     FactoryReturnItem[]
}

model FactoryReturnItem {
  id              String  @id @default(cuid())
  factoryReturnId String
  productId       String
  warehouseId     String
  quantity        Int
  unitCost        Decimal @db.Decimal(12, 2)
  totalCost       Decimal @db.Decimal(12, 2)

  factoryReturn FactoryReturn @relation(fields: [factoryReturnId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
  warehouse     Warehouse     @relation(fields: [warehouseId], references: [id])
}

// ============ Shop Info (Singleton) ============
model ShopInfo {
  id        String   @id @default("shop-info")
  name      String   @default("")
  taxId     String   @default("")
  address   String   @default("") @db.Text
  notes     String   @default("") @db.Text
  logoUrl   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ Sale Returns (คืนสินค้า) ============
model SaleReturn {
  id           String   @id @default(cuid())
  returnNumber String   @unique
  saleId       String
  reason       String?
  totalAmount  Decimal  @default(0) @db.Decimal(12, 2)
  createdById  String
  createdAt    DateTime @default(now())

  sale      Sale             @relation(fields: [saleId], references: [id])
  createdBy User             @relation(fields: [createdById], references: [id])
  items     SaleReturnItem[]
}

model SaleReturnItem {
  id           String  @id @default(cuid())
  saleReturnId String
  saleItemId   String
  productId    String
  warehouseId  String
  quantity     Int
  unitPrice    Decimal @db.Decimal(12, 2)
  totalPrice   Decimal @db.Decimal(12, 2)

  saleReturn SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])
  warehouse  Warehouse  @relation(fields: [warehouseId], references: [id])
}

// ============ Sale Edit Log (ประวัติแก้ไขบิล) ============
model SaleEditLog {
  id        String   @id @default(cuid())
  saleId    String
  userId    String
  action    String   // UPDATE, CANCEL, RETURN
  changes   Json     // snapshot of changes
  createdAt DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

// ============ Quotations (ใบเสนอราคา) ============
model Quotation {
  id              String    @id @default(cuid())
  quotationNumber String    @unique
  customerId      String?
  customerName    String?
  validUntil      DateTime?
  totalAmount     Decimal   @default(0) @db.Decimal(12, 2)
  discount        Decimal   @default(0) @db.Decimal(12, 2)
  notes           String?   @db.Text
  status          String    @default("DRAFT") // DRAFT, SENT, ACCEPTED, EXPIRED
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer  Customer?       @relation(fields: [customerId], references: [id])
  createdBy User            @relation(fields: [createdById], references: [id])
  items     QuotationItem[]
}

model QuotationItem {
  id          String  @id @default(cuid())
  quotationId String
  productId   String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)
  unitName    String?

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])
}
